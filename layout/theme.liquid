<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ page_title }}{% if current_page != 1 %} - Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}</title>

    <meta name="description" content="{{ page_description | escape }}">
    <link rel="canonical" href="{{ canonical_url }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {{ content_for_header }}

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'custom.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="template-{{ template | split: '.' | first | handleize }}">
    {% sections 'header-group' %}
    
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
    
    {% section 'cart-drawer' %}

    <script>
    // ── Fixed header offset ──────────────────────────────────────────────────
    (function () {
      function setHeaderHeight() {
        var h = document.querySelector('.site-header');
        if (h) document.documentElement.style.setProperty('--header-height', h.offsetHeight + 'px');
      }
      setHeaderHeight();
      window.addEventListener('resize', setHeaderHeight);
    })();

    // ── Shared marquee init ──────────────────────────────────────────────────
    // Any element with [data-marquee] gets a seamless infinite scroll.
    // The first child is treated as "one set"; it is cloned until 2× viewport
    // wide, then animated by exactly one set's pixel width.
    function initMarquee(inner) {
      var set = inner.firstElementChild;
      if (!set) return;

      // Clone until inner is at least 2× viewport wide
      while (inner.scrollWidth < window.innerWidth * 2) {
        var clone = set.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        inner.appendChild(clone);
      }
      // One extra for safety
      var extra = set.cloneNode(true);
      extra.setAttribute('aria-hidden', 'true');
      inner.appendChild(extra);

      var setWidth = set.offsetWidth;
      var speed    = inner.dataset.marqueeSpeed || 28; // seconds per loop
      var style    = document.createElement('style');
      var name     = 'mq-' + Math.random().toString(36).slice(2, 7);
      style.textContent =
        '@keyframes ' + name + ' {' +
          'from { transform: translateX(0); }' +
          'to   { transform: translateX(-' + setWidth + 'px); }' +
        '}';
      document.head.appendChild(style);
      inner.style.animation = name + ' ' + speed + 's linear infinite';
    }

    document.querySelectorAll('[data-marquee]').forEach(initMarquee);

    // ── Lerp glow on VIEW PRODUCT + hero CTA buttons ─────────────────────────
    (function () {
      var glows = new Map();

      function trackBtn(btn, clientX, clientY) {
        var rect = btn.getBoundingClientRect();
        var tx = (clientX - rect.left) / rect.width  * 100;
        var ty = (clientY - rect.top)  / rect.height * 100;

        if (!glows.has(btn)) {
          var state = { x: 50, y: 30, tx: tx, ty: ty };
          glows.set(btn, state);
          (function loop() {
            var s = glows.get(btn);
            if (!s) return;
            s.x += (s.tx - s.x) * 0.1;
            s.y += (s.ty - s.y) * 0.1;
            btn.style.setProperty('--glow-x', s.x.toFixed(2) + '%');
            btn.style.setProperty('--glow-y', s.y.toFixed(2) + '%');
            s.raf = requestAnimationFrame(loop);
          })();
        } else {
          var s = glows.get(btn);
          s.tx = tx; s.ty = ty;
        }
      }

      document.addEventListener('mousemove', function (e) {
        // Scent card VIEW PRODUCT
        var card = e.target.closest('.scent-card');
        if (card) {
          var btn = card.querySelector('.quick-view-btn');
          if (btn) trackBtn(btn, e.clientX, e.clientY);
        }
        // Hero CTA
        var cta = e.target.closest('.cta-primary');
        if (cta) trackBtn(cta, e.clientX, e.clientY);
      });

      document.addEventListener('mouseleave', function (e) {
        var el = e.target.closest && (e.target.closest('.quick-view-btn') || e.target.closest('.cta-primary'));
        if (el && glows.has(el)) {
          cancelAnimationFrame(glows.get(el).raf);
          glows.delete(el);
        }
      }, true);
    })();
    </script>
  </body>
</html>

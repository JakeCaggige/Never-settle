<section class="formula-section">
  <div class="formula-inner">
    <div class="formula-icon" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="20" y1="0" x2="20" y2="40" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="0" y1="20" x2="40" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="20" y1="7" x2="20" y2="13" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="20" y1="27" x2="20" y2="33" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="7" y1="20" x2="13" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="27" y1="20" x2="33" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
      </svg>
    </div>

    <h2 class="formula-heading">{{ section.settings.heading | default: 'OUR ANDROSTENONE FORMULA' }}</h2>

    <div class="formula-body">
      {{ section.settings.body | default: 'Androstenone is a naturally occurring scent molecule, which is associated with human chemical signaling and attraction. Found as trace amounts in the body, it pheromones or the white cells people unconsciously process in one another. In fragrance design, androstenone is used not as a traditional note but as a molecular primer that interacts with the wearer\'s skin chemistry, adding depth, warmth, and a potently magnetic presence to a scent. When blended carefully into a cologne, it enhances the fragrance in ways that feel personal and instinctive, creating an effect this is subtly yet memorable.' }}
    </div>

    <p class="formula-tagline">{{ section.settings.tagline | default: 'DOMINATE. WIN. NEVER SETTLE.' }}</p>

    <div class="formula-icon formula-icon--bottom" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="20" y1="0" x2="20" y2="40" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="0" y1="20" x2="40" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="20" y1="7" x2="20" y2="13" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="20" y1="27" x2="20" y2="33" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="7" y1="20" x2="13" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="27" y1="20" x2="33" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
      </svg>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Androstenone Formula",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR ANDROSTENONE FORMULA"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy",
      "default": "Androstenone is a naturally occurring scent molecule, which is associated with human chemical signaling and attraction. Found as trace amounts in the body, it pheromones or the white cells people unconsciously process in one another. In fragrance design, androstenone is used not as a traditional note but as a molecular primer that interacts with the wearer's skin chemistry, adding depth, warmth, and a potently magnetic presence to a scent. When blended carefully into a cologne, it enhances the fragrance in ways that feel personal and instinctive, creating an effect this is subtly yet memorable."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "DOMINATE. WIN. NEVER SETTLE."
    }
  ],
  "presets": [
    {
      "name": "Androstenone Formula"
    }
  ]
}
{% endschema %}

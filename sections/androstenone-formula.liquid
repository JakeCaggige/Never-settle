<section class="formula-section">
  <div class="formula-divider" aria-hidden="true"></div>
  <div class="formula-inner">
    {% if section.settings.molecule_image != blank %}
      <div class="formula-molecule">
        <img src="{{ section.settings.molecule_image | image_url: width: 200 }}" alt="Androstenone molecule" loading="lazy">
      </div>
    {% endif %}

    <h2 class="formula-heading">{{ section.settings.heading }}</h2>

    <div class="formula-body">
      {{ section.settings.body }}
    </div>

    <p class="formula-tagline">{{ section.settings.tagline }}</p>

    <div class="formula-icon" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="20" y1="0" x2="20" y2="40" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="0" y1="20" x2="40" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="20" y1="7" x2="20" y2="13" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="20" y1="27" x2="20" y2="33" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="7" y1="20" x2="13" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
        <line x1="27" y1="20" x2="33" y2="20" stroke="#D4AF37" stroke-width="1.5"/>
      </svg>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Androstenone Formula",
  "settings": [
    {
      "type": "image_picker",
      "id": "molecule_image",
      "label": "Molecule diagram image",
      "info": "Upload the Androstenone molecular structure SVG/PNG (approx 200px wide)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR ANDROSTENONE FORMULA"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy",
      "default": "Androstenone is a naturally occurring scent molecule often associated with human chemical signaling and attraction. Found in trace amounts in the body, it contributes to the subtle cues people unconsciously perceive in one another. In fragrance design, androstenone is used not as a traditional note but as a molecular accent that interacts with the wearer's skin chemistry, adding depth, warmth, and a quietly magnetic presence to a scent. When blended carefully into a cologne, it enhances the fragrance in a way that feels personal and instinctive, creating an effect that is subtle yet memorable."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "DOMINATE. WIN. NEVER SETTLE."
    }
  ],
  "presets": [
    {
      "name": "Androstenone Formula"
    }
  ]
}
{% endschema %}

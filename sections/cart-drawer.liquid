<div id="cart-drawer" class="cart-drawer">
  <div class="cart-drawer-overlay"></div>
  <div class="cart-drawer-content">
    <div class="cart-drawer-header">
      <h2>CART</h2>
      <button class="cart-close" aria-label="Close cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="4" y1="4" x2="20" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="20" y1="4" x2="4" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer-items" id="cart-items">
      <!-- Cart items loaded via JavaScript -->
    </div>

    <div class="cart-drawer-footer">
      <div class="cart-total">
        <span>TOTAL:</span>
        <span id="cart-total-price">$0.00</span>
      </div>
      <a href="/checkout" class="cta-primary cart-checkout">CHECKOUT</a>
      <a href="/cart" class="cart-view-link">View Full Cart</a>
    </div>
  </div>
</div>

<style>
.cart-drawer {
  position: fixed;
  inset: 0;
  z-index: 1000;
  pointer-events: none;
}

.cart-drawer.active {
  pointer-events: auto;
}

.cart-drawer-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.8);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.cart-drawer.active .cart-drawer-overlay {
  opacity: 1;
}

.cart-drawer-content {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  max-width: 450px;
  background: var(--color-black);
  border-left: 1px solid var(--color-white-10);
  transform: translateX(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.cart-drawer.active .cart-drawer-content {
  transform: translateX(0);
}

.cart-drawer-header {
  padding: 32px;
  border-bottom: 1px solid var(--color-white-10);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-drawer-header h2 {
  font-family: var(--font-heading);
  font-size: 24px;
  letter-spacing: 2.4px;
  color: var(--color-white);
}

.cart-close {
  background: transparent;
  border: none;
  color: var(--color-white);
  font-size: 32px;
  cursor: pointer;
  padding: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.3s ease;
}

.cart-close:hover {
  color: var(--color-gold);
}

.cart-drawer-items {
  flex: 1;
  overflow-y: auto;
  padding: 32px;
}

.cart-item {
  display: flex;
  gap: 16px;
  padding-bottom: 24px;
  margin-bottom: 24px;
  border-bottom: 1px solid var(--color-white-10);
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-item-image {
  width: 100px;
  height: 100px;
  background: #1a1a1a;
  border-radius: 4px;
  overflow: hidden;
  flex-shrink: 0;
}

.cart-item-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cart-item-details {
  flex: 1;
}

.cart-item-title {
  font-family: var(--font-heading);
  font-size: 18px;
  letter-spacing: 1.8px;
  color: var(--color-white);
  margin-bottom: 8px;
}

.cart-item-variant {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--color-white-70);
  margin-bottom: 12px;
}

.cart-item-quantity {
  display: flex;
  align-items: center;
  gap: 12px;
}

.cart-item-qty-btn {
  width: 24px;
  height: 24px;
  border: 1px solid var(--color-white-10);
  background: transparent;
  color: var(--color-white);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.cart-item-qty-btn:hover {
  border-color: var(--color-gold);
  color: var(--color-gold);
}

.cart-item-qty-value {
  font-family: var(--font-body);
  color: var(--color-white);
  min-width: 20px;
  text-align: center;
}

.cart-item-price {
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--color-gold);
}

.cart-item-remove {
  background: transparent;
  border: none;
  color: var(--color-white-50);
  font-family: var(--font-body);
  font-size: 14px;
  cursor: pointer;
  text-decoration: underline;
  margin-top: 8px;
  padding: 0;
  transition: color 0.3s ease;
}

.cart-item-remove:hover {
  color: var(--color-white);
}

.cart-drawer-footer {
  padding: 32px;
  border-top: 1px solid var(--color-white-10);
}

.cart-total {
  display: flex;
  justify-content: space-between;
  font-family: var(--font-heading);
  font-size: 20px;
  letter-spacing: 2px;
  color: var(--color-white);
  margin-bottom: 24px;
}

#cart-total-price {
  color: var(--color-gold);
}

.cart-checkout {
  width: 100%;
  margin-bottom: 16px;
}

.cart-view-link {
  display: block;
  text-align: center;
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--color-white-70);
  text-decoration: underline;
  transition: color 0.3s ease;
}

.cart-view-link:hover {
  color: var(--color-gold);
}

.cart-empty {
  text-align: center;
  padding: 64px 32px;
}

.cart-empty p {
  font-family: var(--font-body);
  font-size: 18px;
  color: var(--color-white-70);
  margin-bottom: 24px;
}

@media (max-width: 480px) {
  .cart-drawer-content {
    max-width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Cart Drawer"
}
{% endschema %}

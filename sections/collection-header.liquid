<div class="collection-header">
  <div class="collection-header-icon" aria-hidden="true">
    <img src="{{ 'ns-cross.svg' | asset_url }}" alt="" width="56" height="56" loading="lazy">
  </div>
  <h1 class="collection-title">SHOP SCENTS</h1>
  <p class="collection-description">Six signature scents. Elite pheromone blends. Absolute dominance.</p>
</div>

<style>
.collection-header {
  background: var(--color-black);
  padding: 70px 64px 48px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
}

.collection-header-icon {
  display: flex;
}

.collection-title {
  font-family: var(--font-heading);
  font-weight: 400;
  font-size: 160px;
  line-height: 144px;
  letter-spacing: 8px;
  color: var(--color-white);
}

.collection-description {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 20.8px;
  color: rgba(255, 255, 255, 0.7);
  margin: 0;
}

@media (max-width: 768px) {
  .collection-title { font-size: 72px; line-height: 1; }
}
</style>

{% schema %}
{
  "name": "Collection Header"
}
{% endschema %}

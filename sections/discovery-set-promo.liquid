<section class="ds-promo">
  <div class="ds-promo-card">
  <div class="ds-promo-inner">
    <div class="ds-promo-content">
      <p class="ds-promo-tagline">{{ section.settings.tagline | default: 'TEST ALL THE SCENTS' }}</p>
      <h2 class="ds-promo-heading">{{ section.settings.heading | default: 'DISCOVERY SET' }}</h2>
      <p class="ds-promo-subtitle">{{ section.settings.subtitle | default: 'Legendary unique fragrances for men who refuse to be average' }}</p>
      <a href="{{ section.settings.cta_link | default: '/products/discovery-set' }}" class="cta-primary">
        {{ section.settings.cta_text | default: 'SHOP DISCOVERY SET' }}
      </a>
    </div>
    {% if section.settings.product_image != blank %}
      <div class="ds-promo-image">
        <img src="{{ section.settings.product_image | image_url: width: 700 }}" alt="Discovery Set" loading="lazy">
      </div>
    {% endif %}
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Discovery Set Promo",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image (right side)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "TEST ALL THE SCENTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DISCOVERY SET"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Legendary unique fragrances for men who refuse to be average"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "SHOP DISCOVERY SET"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Discovery Set Promo"
    }
  ]
}
{% endschema %}

<section class="scents-section">
  <div class="section-header">
    <div class="section-title-icon" aria-hidden="true" data-animate data-delay="0">
      <img src="{{ 'ns-cross.svg' | asset_url }}" alt="" width="48" height="48" loading="lazy">
    </div>
    {% if section.settings.section_title != blank %}
      <h2 class="section-title" data-animate data-delay="100">{{ section.settings.section_title }}</h2>
    {% endif %}
    {% if section.settings.section_subtitle != blank %}
      <p class="section-subtitle" data-animate data-delay="200">{{ section.settings.section_subtitle }}</p>
    {% endif %}
  </div>

  <div class="trust-bar fc-trust-bar">
    <div class="trust-bar-inner" data-marquee>
      <div class="trust-bar-set">
        <div class="trust-badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M3 3h18v4H3V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 7v14h18V7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 7v6l3-2 3 2V7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg><span>Free Shipping $75+</span></div>
        <span class="trust-bar-divider">—</span>
        <div class="trust-badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M21 12a9 9 0 11-2.636-6.364L21 3v6h-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>30-Day Returns</span></div>
        <span class="trust-bar-divider">—</span>
        <div class="trust-badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 3v18M5 3h14l-3 5 3 5H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Made in USA</span></div>
        <span class="trust-bar-divider">—</span>
        <div class="trust-badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg><span>Premium Pheromone Blends</span></div>
        <span class="trust-bar-divider">—</span>
        <div class="trust-badge"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg><span>Secure Checkout</span></div>
        <span class="trust-bar-divider">—</span>
      </div>
    </div>
  </div>

  <div class="scents-grid">
    {% if section.settings.collection != blank %}
      {% assign featured_col = collections[section.settings.collection] %}
      {% assign products_to_show = section.settings.products_to_show %}

      {% for product in featured_col.products limit: products_to_show %}
        {%- assign badge_label = '' -%}
        {%- for tag in product.tags -%}
          {%- assign tag_lower = tag | downcase -%}
          {%- if tag_lower == 'top seller' -%}{%- assign badge_label = 'Top Seller' -%}{%- endif -%}
          {%- if tag_lower == 'new scent' or tag_lower == 'new item' -%}{%- assign badge_label = 'New Scent' -%}{%- endif -%}
        {%- endfor -%}
        {%- assign card_delay = forloop.index0 | times: 100 -%}

        <a href="{{ product.url }}" class="scent-card" data-animate data-delay="{{ card_delay }}">
          <div class="scent-card-image">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy">
            {% endif %}
          </div>
          <div class="scent-card-overlay"></div>

          {% if badge_label != '' %}
            <span class="scent-badge-label">{{ badge_label }}</span>
          {% endif %}

          <div class="scent-card-content">
            <h3 class="scent-name">{{ product.title | upcase }}</h3>
            <div class="scent-pill-row">
              {%- for tag in product.tags -%}
                {%- assign tl = tag | downcase -%}
                {%- if tl == 'wood' or tl == 'leather' or tl == 'citrus' or tl == 'musk' or tl == 'spice' or tl == 'floral' -%}
                  <span class="scent-pill scent-pill--{{ tl }}">
                    <span class="scent-pill-dot"></span>
                    {{ tag | upcase }}
                  </span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>

          <div class="quick-view-btn">VIEW PRODUCT</div>
        </a>
      {% endfor %}

    {% else %}
      {% comment %} Placeholder cards for theme editor preview {% endcomment %}
      {% assign placeholder_names = "BLACK TIGER,KING OF CARNAGE,GHOST HER,∞+1,000,000,000,000+1,THE GOAT,ALPHA BOSS" | split: "," %}
      {% assign placeholder_badges = "Top Seller,New Scent,New Scent,New Scent,New Scent,New Scent" | split: "," %}
      {% for i in (1..6) %}
        <div class="scent-card">
          <div class="scent-card-image" style="background: linear-gradient(180deg, #0a0a0a 0%, #1a1a1a 100%); min-height: 400px;"></div>
          <div class="scent-card-overlay"></div>
          <span class="scent-badge-label">{{ placeholder_badges[forloop.index0] }}</span>
          <div class="scent-card-content">
            <h3 class="scent-name">{{ placeholder_names[forloop.index0] }}</h3>
            <div class="scent-pill-row">
              <span class="scent-pill scent-pill--wood"><span class="scent-pill-dot"></span>WOOD</span>
              <span class="scent-pill scent-pill--leather"><span class="scent-pill-dot"></span>LEATHER</span>
              <span class="scent-pill scent-pill--citrus"><span class="scent-pill-dot"></span>CITRUS</span>
            </div>
          </div>
          <div class="quick-view-btn">VIEW PRODUCT</div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "THE COLLECTION"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section subtitle",
      "default": "Six signature scents. Elite pheromone blends. Absolute dominance."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}

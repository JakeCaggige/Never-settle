<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      {% for block in section.blocks %}
        <div class="footer-section" {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <h4>{{ block.settings.heading }}</h4>
          {% endif %}

          <div class="footer-links">
            {% if block.settings.menu != blank %}
              {% for link in linklists[block.settings.menu].links %}
                <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      {% endfor %}

      <div class="footer-join-save">
        {% if section.settings.join_image != blank %}
          <img
            src="{{ section.settings.join_image | image_url: width: 400 }}"
            alt="Join & Save"
            class="footer-join-image"
            loading="lazy"
          >
        {% endif %}
        <div class="footer-join-content">
          <p class="footer-join-heading">JOIN &amp; SAVE</p>
          <a href="{{ section.settings.join_url | default: '#' }}" class="btn-gold footer-join-btn">
            {{ section.settings.join_cta | default: 'JOIN THE WINNERS CIRCLE' }}
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {{ 'now' | date: '%Y' }} {{ shop.name | upcase }}. ALL RIGHTS RESERVED.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "join_image",
      "label": "JOIN & SAVE — background image",
      "info": "Model image shown in the footer JOIN & SAVE box"
    },
    {
      "type": "text",
      "id": "join_cta",
      "label": "JOIN & SAVE — button text",
      "default": "JOIN THE WINNERS CIRCLE"
    },
    {
      "type": "url",
      "id": "join_url",
      "label": "JOIN & SAVE — button link"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Footer Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "SHOP"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "link_list",
          "settings": { "heading": "COMPANY" }
        },
        {
          "type": "link_list",
          "settings": { "heading": "SUPPORT" }
        },
        {
          "type": "link_list",
          "settings": { "heading": "SHOP" }
        },
        {
          "type": "link_list",
          "settings": { "heading": "CONNECT" }
        }
      ]
    }
  ]
}
{% endschema %}

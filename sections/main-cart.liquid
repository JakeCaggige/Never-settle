<div class="cart-page">
  <div class="cart-page-inner">

    {% if cart.item_count == 0 %}
      <div class="cart-empty-state">
        <p class="cart-empty-heading">YOUR CART IS EMPTY</p>
        <a href="/collections/all" class="btn-gold">SHOP NOW</a>
      </div>
    {% else %}

      <div class="cart-body">

        {% comment %} LEFT — Items table {% endcomment %}
        <div class="cart-items-col">
          <table class="cart-table">
            <colgroup>
              <col class="col-product">
              <col class="col-price">
              <col class="col-qty">
              <col class="col-total">
              <col class="col-remove">
            </colgroup>
            <thead>
              <tr>
                <th class="col-label">PRODUCT</th>
                <th class="col-label">PRICE</th>
                <th class="col-label">QUANTITY</th>
                <th class="col-label">TOTAL</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {% for item in cart.items %}
                <tr class="cart-item" data-item-key="{{ item.key }}">
                  <td class="td-product">
                    <div class="item-info">
                      <div class="item-img">
                        {% if item.image %}
                          <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.product.title }}" loading="lazy">
                        {% endif %}
                      </div>
                      <div class="item-meta">
                        <div class="item-name">{{ item.product.title | upcase }}</div>
                        {% if item.variant.title != 'Default Title' %}
                          <div class="item-variant">{{ item.variant.title }}</div>
                        {% endif %}
                      </div>
                    </div>
                  </td>
                  <td class="td-center item-price">{{ item.original_price | money }}</td>
                  <td class="td-center">
                    <div class="qty-wrapper">
                      <button class="qty-btn" data-action="decrease" data-key="{{ item.key }}" aria-label="Decrease quantity">−</button>
                      <span class="qty-value">{{ item.quantity }}</span>
                      <button class="qty-btn" data-action="increase" data-key="{{ item.key }}" aria-label="Increase quantity">+</button>
                    </div>
                  </td>
                  <td class="td-center item-total">{{ item.final_line_price | money }}</td>
                  <td class="td-remove">
                    <button class="remove-btn" data-key="{{ item.key }}" aria-label="Remove item">×</button>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {% comment %} RIGHT — Order Summary {% endcomment %}
        <div class="order-summary">
          <h2 class="summary-title">ORDER SUMMARY</h2>

          <div class="summary-row">
            <span class="summary-label">Subtotal ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})</span>
            <span class="summary-value">{{ cart.total_price | money }}</span>
          </div>
          <div class="summary-row">
            <span class="summary-label">Shipping</span>
            <span class="summary-value summary-note-text">Calculated at checkout</span>
          </div>

          <div class="summary-divider"></div>

          <div class="summary-total-row">
            <span class="total-label">ESTIMATED TOTAL</span>
            <span class="total-value">{{ cart.total_price | money }}</span>
          </div>

          <a href="/checkout" class="cart-checkout-btn">PROCEED TO CHECKOUT →</a>
          <a href="/collections/all" class="cart-continue-link">← CONTINUE SHOPPING</a>

          <div class="summary-notes">
            <div class="summary-note">✓ Free shipping on orders over $75</div>
            <div class="summary-note">✓ 30-day money back guarantee</div>
            <div class="summary-note">🔒 Secure checkout powered by Shopify</div>
          </div>
        </div>

      </div>
    {% endif %}

  </div>
</div>

<style>
.cart-page {
  background: var(--color-black);
  min-height: 60vh;
  padding: 80px 64px;
}

.cart-page-inner {
  max-width: 1400px;
  margin: 0 auto;
}

/* Empty state */
.cart-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
  padding: 120px 0;
  text-align: center;
}

.cart-empty-heading {
  font-family: var(--font-heading);
  font-size: 64px;
  letter-spacing: 6px;
  color: var(--color-white);
}

/* Two-column layout */
.cart-body {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 64px;
  align-items: start;
}

/* Table */
.cart-table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
}

/* Column widths */
.cart-table col.col-product { width: 40%; }
.cart-table col.col-price   { width: 18%; }
.cart-table col.col-qty     { width: 22%; }
.cart-table col.col-total   { width: 15%; }
.cart-table col.col-remove  { width: 5%; }

/* Header row */
.cart-table thead th {
  font-family: var(--font-heading);
  font-size: 13px;
  letter-spacing: 2px;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  font-weight: 400;
  text-align: center;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.cart-table thead th:first-child { text-align: left; }
.cart-table thead th:last-child  { text-align: right; }

/* Item rows */
.cart-item td {
  padding: 24px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  vertical-align: middle;
}

.td-product { text-align: left; }
.td-center  { text-align: center; }
.td-remove  { text-align: right; }

.item-info {
  display: flex;
  align-items: center;
  gap: 20px;
}

.item-img {
  width: 88px;
  height: 88px;
  flex-shrink: 0;
  background: #111;
  overflow: hidden;
}

.item-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.item-name {
  font-family: var(--font-heading);
  font-size: 16px;
  letter-spacing: 1.5px;
  color: var(--color-white);
  margin-bottom: 4px;
}

.item-variant {
  font-family: var(--font-body);
  font-size: 14px;
  color: rgba(255,255,255,0.5);
}

.item-price,
.item-total {
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--color-white);
}

/* Qty controls */
.qty-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255,255,255,0.15);
  width: 110px;
  margin: 0 auto;
}

.qty-btn {
  background: transparent;
  border: none;
  color: var(--color-white);
  font-size: 18px;
  width: 36px;
  height: 38px;
  cursor: pointer;
  transition: color 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn:hover { color: var(--color-gold); }

.qty-value {
  font-family: var(--font-heading);
  font-size: 16px;
  color: var(--color-white);
  width: 38px;
  text-align: center;
  border-left: 1px solid rgba(255,255,255,0.15);
  border-right: 1px solid rgba(255,255,255,0.15);
  line-height: 38px;
}

.remove-btn {
  background: transparent;
  border: none;
  color: rgba(255,255,255,0.3);
  font-size: 22px;
  cursor: pointer;
  transition: color 0.2s ease;
  padding: 0;
  line-height: 1;
  display: block;
  margin-left: auto;
}

.remove-btn:hover { color: var(--color-white); }

/* Order summary sidebar */
.order-summary {
  background: rgba(255,255,255,0.02);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 4px;
  padding: 37px;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.summary-title {
  font-family: var(--font-heading);
  font-size: 28px;
  letter-spacing: 3px;
  color: var(--color-white);
  margin-bottom: 32px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.summary-label {
  font-family: var(--font-body);
  font-size: 16px;
  color: rgba(255,255,255,0.6);
}

.summary-value {
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--color-white);
}

.summary-note-text {
  font-size: 13px;
  color: rgba(255,255,255,0.4);
}

.summary-divider {
  height: 1px;
  background: rgba(255,255,255,0.1);
  margin: 16px 0 24px;
}

.summary-total-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 32px;
}

.total-label {
  font-family: var(--font-heading);
  font-size: 16px;
  letter-spacing: 2px;
  color: rgba(255,255,255,0.8);
}

.total-value {
  font-family: var(--font-heading);
  font-size: 28px;
  letter-spacing: 2px;
  color: var(--color-gold);
}

.cart-checkout-btn {
  display: block;
  width: 100%;
  background: var(--color-gold);
  color: var(--color-black);
  font-family: var(--font-heading);
  font-size: 16px;
  letter-spacing: 2px;
  padding: 18px;
  text-align: center;
  transition: opacity 0.2s ease;
  margin-bottom: 16px;
}

.cart-checkout-btn:hover { opacity: 0.9; }

.cart-continue-link {
  display: block;
  text-align: center;
  font-family: var(--font-heading);
  font-size: 13px;
  letter-spacing: 2px;
  color: rgba(255,255,255,0.5);
  transition: color 0.2s ease;
  margin-bottom: 32px;
}

.cart-continue-link:hover { color: var(--color-white); }

.summary-notes {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.summary-note {
  font-family: var(--font-body);
  font-size: 13px;
  color: rgba(255,255,255,0.4);
}

@media (max-width: 1024px) {
  .cart-body {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .cart-page { padding: 48px 24px; }

  .cart-table thead { display: none; }

  .cart-table,
  .cart-table tbody,
  .cart-item,
  .cart-item td { display: block; width: 100%; }

  .cart-item {
    padding: 24px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .cart-item td {
    padding: 0;
    border: none;
    text-align: left;
  }

  .cart-item td + td { margin-top: 12px; }

  .qty-wrapper { margin: 0; }
  .remove-btn  { margin-left: 0; }
}
</style>

<script>
(function() {
  function updateCartItem(key, quantity) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: quantity })
    }).then(() => window.location.reload());
  }

  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.qty-btn');
    if (btn) {
      const key = btn.dataset.key;
      const row = btn.closest('[data-item-key]');
      const current = parseInt(row.querySelector('.qty-value').textContent, 10);
      const next = btn.dataset.action === 'increase' ? current + 1 : current - 1;
      updateCartItem(key, next < 1 ? 0 : next);
    }

    const remove = e.target.closest('.remove-btn');
    if (remove) {
      updateCartItem(remove.dataset.key, 0);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Cart Page"
}
{% endschema %}

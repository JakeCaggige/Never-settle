<div class="collection-products">
  <div class="scents-grid">
    {% for product in collection.products %}
      {%- if product.handle == 'discovery-set' -%}{%- continue -%}{%- endif -%}
      {%- assign badge_label = '' -%}
      {%- for tag in product.tags -%}
        {%- assign tag_lower = tag | downcase -%}
        {%- if tag_lower == 'top seller' -%}{%- assign badge_label = 'Top Seller' -%}{%- endif -%}
        {%- if tag_lower == 'new scent' or tag_lower == 'new item' -%}{%- assign badge_label = 'New Scent' -%}{%- endif -%}
      {%- endfor -%}

      <a href="{{ product.url }}" class="scent-card">
        <div class="scent-card-image">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" loading="lazy">
          {% endif %}
        </div>
        <div class="scent-card-overlay"></div>

        {% if badge_label != '' %}
          <span class="scent-badge-label">{{ badge_label }}</span>
        {% endif %}

        <div class="scent-card-content">
          <h3 class="scent-name">{{ product.title | upcase }}</h3>
          <div class="scent-pill-row">
            {%- for tag in product.tags -%}
              {%- assign tl = tag | downcase -%}
              {%- if tl == 'wood' or tl == 'leather' or tl == 'citrus' or tl == 'musk' or tl == 'spice' or tl == 'floral' -%}
                <span class="scent-pill scent-pill--{{ tl }}">
                  <span class="scent-pill-dot"></span>
                  {{ tag | upcase }}
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <div class="quick-view-btn">VIEW PRODUCT</div>
      </a>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="pagination">
      {% if paginate.previous %}
        <a href="{{ paginate.previous.url }}" class="pagination-link">← Previous</a>
      {% endif %}
      {% for part in paginate.parts %}
        {% if part.is_link %}
          <a href="{{ part.url }}" class="pagination-link">{{ part.title }}</a>
        {% else %}
          <span class="pagination-current">{{ part.title }}</span>
        {% endif %}
      {% endfor %}
      {% if paginate.next %}
        <a href="{{ paginate.next.url }}" class="pagination-link">Next →</a>
      {% endif %}
    </div>
  {% endif %}
</div>

<style>
.collection-products {
  background: var(--color-black);
  padding: 0 0 128px;
}

.pagination {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-top: 64px;
  padding: 0 64px;
}

.pagination-link,
.pagination-current {
  padding: 12px 20px;
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--color-white);
  border: 1px solid var(--color-white-10);
  transition: all 0.3s ease;
}

.pagination-link:hover {
  border-color: var(--color-gold);
  background: var(--color-white-5);
}

.pagination-current {
  background: var(--color-gold);
  color: var(--color-black);
  border-color: var(--color-gold);
}
</style>

{% schema %}
{
  "name": "Collection Products"
}
{% endschema %}

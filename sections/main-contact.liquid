<div class="contact-page">
  <div class="contact-wrapper">
    <div class="contact-info-side">
      <div class="contact-info-card">
        <h2 class="contact-heading">CONTACT US</h2>
        <div class="contact-item">
          <span class="contact-icon">✉</span>
          <div class="contact-text">
            <h4>Email</h4>
            <p>support@neversettle.com</p>
          </div>
        </div>
        <div class="contact-item">
          <span class="contact-icon">🕐</span>
          <div class="contact-text">
            <h4>Response Time</h4>
            <p>We respond within 24 hours, Monday – Friday</p>
          </div>
        </div>
        <div class="contact-item">
          <span class="contact-icon">📦</span>
          <div class="contact-text">
            <h4>Orders &amp; Shipping</h4>
            <p>For order inquiries, please have your order number ready.</p>
          </div>
        </div>
        <div class="contact-item">
          <span class="contact-icon">↩</span>
          <div class="contact-text">
            <h4>Returns &amp; Exchanges</h4>
            <p>We offer a 30-day money back guarantee on all orders.</p>
          </div>
        </div>
      </div>

      <div class="contact-social-card">
        <h3 class="contact-social-heading">FOLLOW US</h3>
        <div class="contact-social-links">
          <a href="https://instagram.com" class="social-btn" target="_blank" rel="noopener">
            <span>IG</span> Instagram
          </a>
          <a href="https://tiktok.com" class="social-btn" target="_blank" rel="noopener">
            <span>TT</span> TikTok
          </a>
          <a href="https://youtube.com" class="social-btn" target="_blank" rel="noopener">
            <span>YT</span> YouTube
          </a>
        </div>
      </div>
    </div>

    <div class="contact-form-side">
      <h2 class="contact-form-heading">SEND US A MESSAGE</h2>
      <p class="contact-form-sub">Have a question about your order, our fragrances, or anything else? We typically respond within 24 hours.</p>

      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="contact-success">Message sent! We'll get back to you within 24 hours.</p>
        {% endif %}
        {% if form.errors %}
          <p class="contact-error">{{ form.errors | default_errors }}</p>
        {% endif %}
        <div class="contact-row">
          <div class="contact-field">
            <label for="contact-first-name">First Name</label>
            <input type="text" id="contact-first-name" name="contact[first_name]" placeholder="John">
          </div>
          <div class="contact-field">
            <label for="contact-last-name">Last Name</label>
            <input type="text" id="contact-last-name" name="contact[last_name]" placeholder="Doe">
          </div>
        </div>
        <div class="contact-field">
          <label for="contact-email">Email Address</label>
          <input type="email" id="contact-email" name="contact[email]" placeholder="john@example.com" required>
        </div>
        <div class="contact-field">
          <label for="contact-order">Order Number (Optional)</label>
          <input type="text" id="contact-order" name="contact[order_number]" placeholder="#NS-00000">
        </div>
        <div class="contact-field">
          <label for="contact-subject">Subject</label>
          <input type="text" id="contact-subject" name="contact[subject]" placeholder="How can we help?">
        </div>
        <div class="contact-field">
          <label for="contact-message">Message</label>
          <textarea id="contact-message" name="contact[body]" placeholder="Tell us more..." rows="5"></textarea>
        </div>
        <button type="submit" class="contact-submit">Send Message &rarr;</button>
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Page"
}
{% endschema %}

<div class="product-page">
  <div class="product-hero">

    {% comment %} LEFT — Sticky gallery {% endcomment %}
    <div class="product-gallery">
      <div class="product-main-image">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title }}" id="main-product-image">
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-thumbnails">
          {% for image in product.images limit: 4 %}
            <div class="thumbnail {% if forloop.first %}active{% endif %}" data-image-url="{{ image | image_url: width: 900 }}">
              <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title }}">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% comment %} RIGHT — Product info {% endcomment %}
    <div class="product-info">

      <div class="trust-bar product-trust-bar">
        <div class="trust-bar-inner" data-marquee>
          <div class="trust-bar-set">
            <div class="trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M3 3h18v4H3V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 7v14h18V7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 7v6l3-2 3 2V7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg><span>Free Shipping $75+</span></div>
            <span class="trust-bar-divider">—</span>
            <div class="trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M21 12a9 9 0 11-2.636-6.364L21 3v6h-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>30-Day Returns</span></div>
            <span class="trust-bar-divider">—</span>
            <div class="trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 3v18M5 3h14l-3 5 3 5H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Made in USA</span></div>
            <span class="trust-bar-divider">—</span>
            <div class="trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg><span>Premium Pheromone Blends</span></div>
            <span class="trust-bar-divider">—</span>
            <div class="trust-badge"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg><span>Secure Checkout</span></div>
            <span class="trust-bar-divider">—</span>
          </div>
        </div>
      </div>

      <h1 class="product-title" data-animate data-delay="0">{{ product.title | upcase }}</h1>

      {% comment %} Fragrance note pills — blocks override tags {% endcomment %}
      {%- assign note_blocks = section.blocks | where: 'type', 'fragrance_note' -%}
      <div class="scent-pill-row product-scent-pills" data-animate data-delay="80">
        {% if note_blocks.size > 0 %}
          {% for block in note_blocks %}
            <span class="scent-pill scent-pill--custom" {{ block.shopify_attributes }}>
              <span class="scent-pill-dot"
                {% if block.settings.dot_image != blank %}
                  style="background-image: url('{{ block.settings.dot_image | image_url: width: 40 }}'); background-size: cover; background-position: center;"
                {% endif %}
              ></span>
              {{ block.settings.label | upcase }}
            </span>
          {% endfor %}
        {% else %}
          {%- for tag in product.tags -%}
            {%- assign tl = tag | downcase -%}
            {%- if tl == 'wood' or tl == 'leather' or tl == 'citrus' or tl == 'musk' or tl == 'spice' or tl == 'floral' -%}
              <span class="scent-pill scent-pill--{{ tl }}">
                <span class="scent-pill-dot"></span>{{ tag | upcase }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        {% endif %}
      </div>

      {% comment %} Price + Rating row {% endcomment %}
      <div class="product-price-rating" data-animate data-delay="160">
        <div class="product-price" id="product-price">{{ product.price | money }}</div>
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="review-count">({{ product.metafields.custom.review_count | default: 127 }} reviews)</span>
        </div>
      </div>

      <p class="product-description" data-animate data-delay="240">{{ product.description }}</p>

      {% comment %} Size + Add to Cart {% endcomment %}
      <form action="/cart/add" method="post" enctype="multipart/form-data" data-animate data-delay="320">
        {% unless product.has_only_default_variant %}
          <div class="product-options">
            <label class="option-label">SIZE</label>
            <div class="size-options">
              {% for variant in product.variants %}
                <button type="button" class="size-option {% if forloop.first %}active{% endif %}" data-variant-id="{{ variant.id }}" data-price="{{ variant.price }}">
                  {{ variant.title }}{% if variant.price %} — {{ variant.price | money_without_trailing_zeros }}{% endif %}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endunless %}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="product-variant-id">

        <div class="add-to-cart-section">
          <button type="submit" class="btn-add-to-cart" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}ADD TO CART{% else %}SOLD OUT{% endif %}
          </button>
        </div>
      </form>

      {% comment %} Shipping / trust row {% endcomment %}
      <div class="shipping-info" data-animate data-delay="400">
        <div class="shipping-item">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" stroke="currentColor" stroke-width="1.5" rx="1"/>
            <path d="M16 8h3l3 5v4h-6V8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <span>FREE SHIPPING ON ORDERS $75+</span>
        </div>
        <div class="shipping-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M5 3v18M5 3h14l-3 5 3 5H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>MADE IN USA WITH PREMIUM INGREDIENTS</span>
        </div>
      </div>

      {% comment %} Core features — 4 individual bordered cards in 2×2 {% endcomment %}
      <div class="core-features" data-animate data-delay="480">
        <div class="core-feature">
          <svg width="19" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2C8 2 4 5 4 10c0 4 3 7 6 9l2 1 2-1c3-2 6-5 6-9 0-5-4-8-8-8z" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <span>ESSENTIAL GRADE PHEROMONES</span>
        </div>
        <div class="core-feature">
          <svg width="20" height="21" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>LONG LASTING</span>
        </div>
        <div class="core-feature">
          <svg width="17" height="21" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          <span>DOMINANT SCENT PROFILES</span>
        </div>
        <div class="core-feature">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>MORE POWERFUL THAN ALL COMPETITORS</span>
        </div>
      </div>

      {% comment %} Fragrance Profile {% endcomment %}
      <div class="product-detail-box">
        <h3 class="detail-box-heading">FRAGRANCE PROFILE</h3>
        <div class="detail-box-rows">
          <p class="detail-row">
            <strong>Top Notes:</strong> {{ product.metafields.custom.top_notes | default: 'Bergamot, Black Pepper, Cardamom' }}
          </p>
          <p class="detail-row">
            <strong>Heart Notes:</strong> {{ product.metafields.custom.heart_notes | default: 'Leather, Tobacco, Vetiver' }}
          </p>
          <p class="detail-row">
            <strong>Base Notes:</strong> {{ product.metafields.custom.base_notes | default: 'Oud, Amber, Musk' }}
          </p>
        </div>
      </div>

      {% comment %} Performance {% endcomment %}
      <div class="product-detail-box">
        <h3 class="detail-box-heading">PERFORMANCE</h3>
        <div class="detail-box-rows">
          <p class="detail-row">
            <strong>Intensity:</strong> {{ product.metafields.custom.intensity | default: 'Bold' }}
          </p>
          <p class="detail-row">
            <strong>Longevity:</strong> {{ product.metafields.custom.longevity | default: '8-10 hours' }}
          </p>
          <p class="detail-row">
            <strong>Projection:</strong> {{ product.metafields.custom.projection | default: 'Moderate-Strong' }}
          </p>
          <p class="detail-row">
            <strong>Season:</strong> {{ product.metafields.custom.season | default: 'Fall/Winter' }}
          </p>
        </div>
      </div>

    </div>
  </div>

  {% comment %} Customer Reviews {% endcomment %}
  <div class="reviews-section">
    <div class="reviews-header">
      <div class="reviews-summary">
        <h2 class="reviews-heading">CUSTOMER REVIEWS</h2>
        <div class="reviews-overall">
          <span class="stars">★★★★★</span>
          <span class="reviews-count">4.9 out of 5 based on {{ product.metafields.custom.review_count | default: 127 }} reviews</span>
        </div>
      </div>
      <a href="#write-review" class="btn-outline">WRITE A REVIEW</a>
    </div>
    <div class="reviews-list">
      <div class="review-card">
        <div class="review-meta">
          <div>
            <div class="reviewer-name">Marcus T.</div>
            <div class="review-stars">★★★★★</div>
          </div>
          <span class="review-date">Verified Purchase</span>
        </div>
        <p class="review-body">"Absolute game changer. The projection is insane and I get compliments everywhere I go. Finally a fragrance that lives up to the hype."</p>
      </div>
      <div class="review-card">
        <div class="review-meta">
          <div>
            <div class="reviewer-name">James R.</div>
            <div class="review-stars">★★★★★</div>
          </div>
          <span class="review-date">Verified Purchase</span>
        </div>
        <p class="review-body">"Been wearing designer fragrances for years. This blows them all out of the water. Worth every penny."</p>
      </div>
      <div class="review-card">
        <div class="review-meta">
          <div>
            <div class="reviewer-name">Derek M.</div>
            <div class="review-stars">★★★★★</div>
          </div>
          <span class="review-date">Verified Purchase</span>
        </div>
        <p class="review-body">"The leather and oud combo is perfect. Sophisticated but still masculine. My new signature scent."</p>
      </div>
    </div>
  </div>

  {% comment %} You May Also Like — loaded via Shopify recommendations API {% endcomment %}
  <div class="ymal-section" id="ymal-section" data-product-id="{{ product.id }}">
    <h2 class="ymal-heading">YOU MAY ALSO LIKE</h2>
    <div class="ymal-scents-grid" id="ymal-grid"></div>
  </div>

  <script>
    (function() {
      var productId = document.getElementById('ymal-section').dataset.productId;
      fetch('/recommendations/products.json?product_id=' + productId + '&limit=2')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var grid = document.getElementById('ymal-grid');
          data.products.forEach(function(p) {
            var pills = p.tags.filter(function(t) {
              return ['wood','leather','citrus','musk','spice','floral'].includes(t.toLowerCase());
            }).map(function(t) {
              return '<span class="scent-pill scent-pill--' + t.toLowerCase() + '"><span class="scent-pill-dot"></span>' + t.toUpperCase() + '</span>';
            }).join('');
            var img = p.featured_image ? '<img src="' + p.featured_image.src + '" alt="' + p.title + '" loading="lazy">' : '';
            grid.innerHTML += '<a href="/products/' + p.handle + '" class="scent-card scent-card--ymal">'
              + '<div class="scent-card-image">' + img + '</div>'
              + '<div class="scent-card-overlay"></div>'
              + '<div class="scent-card-content">'
              + '<h3 class="scent-name">' + p.title.toUpperCase() + '</h3>'
              + '<div class="scent-pill-row">' + pills + '</div>'
              + '</div>'
              + '<div class="quick-view-btn">VIEW PRODUCT</div>'
              + '</a>';
          });
        });
    })();
  </script>
</div>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "blocks": [
    {
      "type": "fragrance_note",
      "name": "Fragrance Note",
      "settings": [
        {
          "type": "image_picker",
          "id": "dot_image",
          "label": "Dot icon image",
          "info": "Upload a 40×40px texture image for the pill dot (wood grain, leather, citrus slice, etc.)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Note name",
          "default": "WOOD"
        }
      ]
    }
  ]
}
{% endschema %}

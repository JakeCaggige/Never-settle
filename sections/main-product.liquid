<div class="product-page">
  <div class="product-hero">
    <div class="product-gallery">
      <div class="product-main-image">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" id="main-product-image">
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-thumbnails">
          {% for image in product.images limit: 4 %}
            <div class="thumbnail {% if forloop.first %}active{% endif %}" data-image-url="{{ image | image_url: width: 800 }}">
              <img src="{{ image | image_url: width: 150 }}" alt="{{ product.title }}">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-info">
      <h1>{{ product.title | upcase }}</h1>

      {% comment %} Fragrance note pills — use blocks if set, otherwise fall back to product tags {% endcomment %}
      {%- assign note_blocks = section.blocks | where: 'type', 'fragrance_note' -%}
      {% if note_blocks.size > 0 %}
        <div class="scent-pill-row product-scent-pills">
          {% for block in note_blocks %}
            <span class="scent-pill scent-pill--custom" {{ block.shopify_attributes }}>
              <span class="scent-pill-dot"
                {% if block.settings.dot_image != blank %}
                  style="background-image: url('{{ block.settings.dot_image | image_url: width: 40 }}'); background-size: cover; background-position: center;"
                {% endif %}
              ></span>
              {{ block.settings.label | upcase }}
            </span>
          {% endfor %}
        </div>
      {% else %}
        <div class="scent-pill-row product-scent-pills">
          {%- for tag in product.tags -%}
            {%- assign tl = tag | downcase -%}
            {%- if tl == 'wood' or tl == 'leather' or tl == 'citrus' or tl == 'musk' or tl == 'spice' or tl == 'floral' -%}
              <span class="scent-pill scent-pill--{{ tl }}">
                <span class="scent-pill-dot"></span>
                {{ tag | upcase }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {% endif %}

      {% comment %} Price + Rating on same row {% endcomment %}
      <div class="product-price-rating">
        <div class="product-price">{{ product.price | money }}</div>
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="review-count">({{ product.metafields.custom.review_count | default: 127 }} reviews)</span>
        </div>
      </div>

      <p class="product-description">{{ product.description }}</p>

      <form action="/cart/add" method="post" enctype="multipart/form-data">
        {% unless product.has_only_default_variant %}
          <div class="product-options">
            <label class="option-label">SIZE</label>
            <div class="size-options">
              {% for variant in product.variants %}
                <button type="button" class="size-option {% if forloop.first %}active{% endif %}" data-variant-id="{{ variant.id }}">
                  {{ variant.title }}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endunless %}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="add-to-cart-section">
          <button type="submit" class="cta-primary" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}ADD TO CART{% else %}SOLD OUT{% endif %}
          </button>
        </div>
      </form>

      {% comment %} 2-column shipping row {% endcomment %}
      <div class="shipping-info">
        <div class="shipping-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" stroke="#D4AF37" stroke-width="1.5" rx="1"/>
            <path d="M16 8h3l3 5v4h-6V8z" stroke="#D4AF37" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="5.5" cy="18.5" r="2.5" stroke="#D4AF37" stroke-width="1.5"/>
            <circle cx="18.5" cy="18.5" r="2.5" stroke="#D4AF37" stroke-width="1.5"/>
          </svg>
          <span>Free shipping on orders $75+</span>
        </div>
        <div class="shipping-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="4" y1="22" x2="4" y2="15" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Made in USA with premium ingredients</span>
        </div>
      </div>

      {% comment %} 2x2 core features grid {% endcomment %}
      <div class="core-features">
        <div class="core-feature">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="#D4AF37" stroke-width="1.5"/>
            <path d="M8 12l3 3 5-5" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Essential Grade Pheromones</span>
        </div>
        <div class="core-feature">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="#D4AF37" stroke-width="1.5"/>
            <path d="M12 6v6l4 2" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Long Lasting</span>
        </div>
        <div class="core-feature">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z" stroke="#D4AF37" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          <span>Dominant Scent Profiles</span>
        </div>
        <div class="core-feature">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>More Powerful Than All Competitors</span>
        </div>
      </div>

      {% if product.metafields.custom.fragrance_notes %}
        <div class="notes-section">
          <h3>Fragrance Profile</h3>
          {{ product.metafields.custom.fragrance_notes }}
        </div>
      {% endif %}

      <div class="performance-section">
        <h3 class="performance-heading">PERFORMANCE</h3>
        <div class="performance-grid">
          <div class="performance-item">
            <span class="performance-label">Intensity:</span>
            <span class="performance-value">{{ product.metafields.custom.intensity | default: 'Bold' }}</span>
          </div>
          <div class="performance-item">
            <span class="performance-label">Longevity:</span>
            <span class="performance-value">{{ product.metafields.custom.longevity | default: '8-10 hours' }}</span>
          </div>
          <div class="performance-item">
            <span class="performance-label">Projection:</span>
            <span class="performance-value">{{ product.metafields.custom.projection | default: 'Moderate-Strong' }}</span>
          </div>
          <div class="performance-item">
            <span class="performance-label">Season:</span>
            <span class="performance-value">{{ product.metafields.custom.season | default: 'Fall/Winter' }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% comment %} Customer Reviews {% endcomment %}
  <div class="reviews-section">
    <div class="reviews-header">
      <div class="reviews-summary">
        <h2 class="reviews-heading">CUSTOMER REVIEWS</h2>
        <div class="reviews-overall">
          <span class="stars">★★★★★</span>
          <span class="reviews-count">4.9 out of 5 based on {{ product.metafields.custom.review_count | default: 127 }} reviews</span>
        </div>
      </div>
      <a href="#write-review" class="btn-outline">WRITE A REVIEW</a>
    </div>
    <div class="reviews-list">
      <div class="review-card">
        <div class="review-meta">
          <div>
            <div class="reviewer-name">Marcus T.</div>
            <div class="review-stars">★★★★★</div>
          </div>
          <span class="review-date">Verified Purchase</span>
        </div>
        <p class="review-body">"Absolute game changer. The projection is insane and I get compliments everywhere I go. Finally a fragrance that lives up to the hype."</p>
      </div>
      <div class="review-card">
        <div class="review-meta">
          <div>
            <div class="reviewer-name">James R.</div>
            <div class="review-stars">★★★★★</div>
          </div>
          <span class="review-date">Verified Purchase</span>
        </div>
        <p class="review-body">"Been wearing designer fragrances for years. Black Tiger blows them all out of the water. Worth every penny."</p>
      </div>
      <div class="review-card">
        <div class="review-meta">
          <div>
            <div class="reviewer-name">Derek M.</div>
            <div class="review-stars">★★★★★</div>
          </div>
          <span class="review-date">Verified Purchase</span>
        </div>
        <p class="review-body">"The leather and oud combo is perfect. Sophisticated but still masculine. My new signature scent."</p>
      </div>
    </div>
  </div>

  {% comment %} You May Also Like {% endcomment %}
  <div class="ymal-section">
    <h2 class="ymal-heading">YOU MAY ALSO LIKE</h2>
    <div class="ymal-scents-grid">
      {% assign ymal_count = 0 %}
      {% for rec in collection.products %}
        {% unless rec.id == product.id %}
          {% if ymal_count < 2 %}
            <a href="{{ rec.url }}" class="scent-card scent-card--ymal">
              <div class="scent-card-image">
                {% if rec.featured_image %}
                  <img src="{{ rec.featured_image | image_url: width: 800 }}" alt="{{ rec.title }}" loading="lazy">
                {% endif %}
              </div>
              <div class="scent-card-overlay"></div>
              <div class="scent-card-content">
                <h3 class="scent-name">{{ rec.title | upcase }}</h3>
                <div class="scent-pill-row">
                  {%- for tag in rec.tags -%}
                    {%- assign tl = tag | downcase -%}
                    {%- if tl == 'wood' or tl == 'leather' or tl == 'citrus' or tl == 'musk' or tl == 'spice' or tl == 'floral' -%}
                      <span class="scent-pill scent-pill--{{ tl }}">
                        <span class="scent-pill-dot"></span>
                        {{ tag | upcase }}
                      </span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
              <div class="quick-view-btn">QUICK VIEW</div>
            </a>
            {% assign ymal_count = ymal_count | plus: 1 %}
          {% endif %}
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "blocks": [
    {
      "type": "fragrance_note",
      "name": "Fragrance Note",
      "settings": [
        {
          "type": "image_picker",
          "id": "dot_image",
          "label": "Dot icon image",
          "info": "Upload a 40×40px image (e.g. wood grain, leather texture, citrus slice). Displays as the note pill dot."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Note name",
          "default": "WOOD",
          "info": "Displayed next to the dot (e.g. WOOD, LEATHER, CITRUS)"
        }
      ]
    }
  ]
}
{% endschema %}

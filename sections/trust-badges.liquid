<div class="trust-bar">
  <div class="trust-bar-inner" id="trust-bar-inner">
    <div class="trust-bar-set">
      <div class="trust-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 3h18v4H3V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M3 7v14h18V7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M9 7v6l3-2 3 2V7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <span>Free Shipping $75+</span>
      </div>
      <span class="trust-bar-divider">—</span>
      <div class="trust-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M21 12a9 9 0 11-2.636-6.364L21 3v6h-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>30-Day Returns</span>
      </div>
      <span class="trust-bar-divider">—</span>
      <div class="trust-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 3v18M5 3h14l-3 5 3 5H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Made in USA</span>
      </div>
      <span class="trust-bar-divider">—</span>
      <div class="trust-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <span>Premium Pheromone Blends</span>
      </div>
      <span class="trust-bar-divider">—</span>
      <div class="trust-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="1" stroke="currentColor" stroke-width="1.5"/>
          <path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>Secure Checkout</span>
      </div>
      <span class="trust-bar-divider">—</span>
    </div>
  </div>
</div>

<script>
(function () {
  var inner = document.getElementById('trust-bar-inner');
  var set   = inner && inner.querySelector('.trust-bar-set');
  if (!set) return;

  // Clone until content is at least 2× the viewport wide
  while (inner.scrollWidth < window.innerWidth * 2) {
    var clone = set.cloneNode(true);
    clone.setAttribute('aria-hidden', 'true');
    inner.appendChild(clone);
  }
  // One extra clone for safety
  var extra = set.cloneNode(true);
  extra.setAttribute('aria-hidden', 'true');
  inner.appendChild(extra);

  // Animate by exactly one set's pixel width — perfectly seamless
  var setWidth = set.offsetWidth;
  var style = document.createElement('style');
  style.textContent =
    '@keyframes trust-scroll {' +
      'from { transform: translateX(0); }' +
      'to   { transform: translateX(-' + setWidth + 'px); }' +
    '}';
  document.head.appendChild(style);
})();
</script>

{% schema %}
{
  "name": "Trust Bar"
}
{% endschema %}
